{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "portfolioItems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        },
        "required": ["itemId", "title"]
      }
    }
  },
  "required": ["id", "name"]
}